-- 🌍 BIOME AND EXCEPTION ANALYZER
local validBiomes = {
    ["Birch Glade"] = true,
    ["Enchanted Forest"] = true,
    ["Palv Cove"] = true,
    ["Palm Cove"] = true,
    ["Redwood Forest"] = true,
    ["Sakura Forest"] = true,
    ["Snowy Peak"] = true
}

local function IsValidBiome(name)
    return validBiomes[name] == true
end

local biomeAllowedCommons = {
    ["Birch Glade"] = {"birch"},
    ["Sakura Forest"] = {"sakura"},
    ["Redwood Forest"] = {"redwood"},
    ["Snowy Peak"] = {"fir", "blackthorn"},
    ["Enchanted Forest"] = {"mushroom", "hazel", "chestnut"},
    ["Palv Cove"] = {"oak", "palm"}
}

local biomeCenters = {}
local biomeRadiuses = {}
local biomeProps = {}
local biomePropCounts = {}

task.spawn(function()
    while task.wait(2) do
        if not Workspace:FindFirstChild("Map") then continue end
        for _, folder in ipairs(Workspace.Map:GetChildren()) do
            if (folder:IsA("Folder") or folder:IsA("Model")) and IsValidBiome(folder.Name) then
                local currentCount = biomePropCounts[folder.Name] or 0
                local children = folder:GetChildren()
                if #children > currentCount then
                    local minX, minZ = math.huge, math.huge
                    local maxX, maxZ = -math.huge, -math.huge
                    local props = {}
                    
                    for _, obj in ipairs(children) do
                        local pos = nil
                        if obj:IsA("Model") and obj.PrimaryPart then pos = obj.PrimaryPart.Position
                        elseif obj:IsA("BasePart") then pos = obj.Position end
                        
                        if pos then
                            table.insert(props, pos)
                            minX, minZ = math.min(minX, pos.X), math.min(minZ, pos.Z)
                            maxX, maxZ = math.max(maxX, pos.X), math.max(maxZ, pos.Z)
                        end
                    end
                    
                    if #props > 0 then
                        biomeProps[folder.Name] = props
                        biomePropCounts[folder.Name] = #children
                        biomeCenters[folder.Name] = Vector3.new((minX + maxX)/2, 0, (minZ + maxZ)/2)
                        local diag = math.sqrt((maxX - minX)^2 + (maxZ - minZ)^2)
                        biomeRadiuses[folder.Name] = (diag / 2) + 70 
                    end
                end
            end
        end
    end
end)

PopulateDropdown()

