-- 🪓 AUTO FARM SPATIAL
local function EquipAxe()
    local char = Players.LocalPlayer.Character
    local backpack = Players.LocalPlayer:FindFirstChild("Backpack")
    if not char or not backpack then return false end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return false end

    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") and string.find(string.lower(tool.Name), "axe") then return true end
    end

    for _, tool in ipairs(backpack:GetChildren()) do
        if tool:IsA("Tool") and string.find(string.lower(tool.Name), "axe") then
            humanoid:EquipTool(tool)
            task.wait(0.2)
            return true
        end
    end
    return false
end

local function GetClosestTree()
    local root = Players.LocalPlayer.Character and Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    local closestDist = math.huge
    local closestTree = nil
    local treesFolder = Workspace:FindFirstChild("Trees")
    if not treesFolder then return nil end
    
    for _, tree in pairs(treesFolder:GetChildren()) do
        local treeName = string.lower(tree.Name)
        if string.find(treeName, "debris") then continue end
        
        -- Проверка на нужные типы деревьев
        local isCommon = false
        local matchedCommonName = nil
        local allCommons = {"birch", "blackthorn", "chestnut", "fir", "hazel", "mushroom", "oak", "redwood", "sakura"}
        
        for _, cName in ipairs(allCommons) do
            if string.find(treeName, cName) then
                isCommon = true
                matchedCommonName = cName
                break
            end
        end

        if UIParams.rareOnlyEnabled and isCommon then continue end

        if UIParams.selectedBiome ~= "Nearest" and isCommon then
            local allowedHere = biomeAllowedCommons[UIParams.selectedBiome]
            local ok = false
            if allowedHere then
                for _, a in ipairs(allowedHere) do
                    if a == matchedCommonName then ok = true break end
                end
            end
            if not ok then continue end
        end
        
        local origin = tree:FindFirstChild("Origin")
        if not origin or not origin:FindFirstChild("TreeHealth") or origin:FindFirstChild("TreeGrowInfo") then continue end
        
        if blacklistedTrees[tree] and os.clock() < blacklistedTrees[tree] then continue end
        
        local seed = tree:GetAttribute("Seed")
        local culled = tree:GetAttribute("TreeCulled")
        local owner = tree:GetAttribute("Owner")
        
        if seed and culled == false and owner == nil then
            local pivot = tree:GetPivot()
            
            if UIParams.selectedBiome ~= "Nearest" then
                local bCenter = biomeCenters[UIParams.selectedBiome]
                local bRadius = biomeRadiuses[UIParams.selectedBiome]
                if bCenter and bRadius then
                    local distToCenter = math.sqrt((pivot.Position.X - bCenter.X)^2 + (pivot.Position.Z - bCenter.Z)^2)
                    if distToCenter > bRadius then
                        continue 
                    end
                end
            end
            
            -- Проверка на исключенные биомы
            local inBlacklistedBiome = false
            local blacklisted = {"Palv Cove", "Palm Cove"}
            for _, bName in ipairs(blacklisted) do
                if biomeCenters[bName] and biomeRadiuses[bName] then
                    local bx = biomeCenters[bName].X
                    local bz = biomeCenters[bName].Z
                    local distToCenter = math.sqrt((pivot.Position.X - bx)^2 + (pivot.Position.Z - bz)^2)
                    if distToCenter <= biomeRadiuses[bName] * 1.1 then
                        inBlacklistedBiome = true
                        break
                    end
                end
            end
            if inBlacklistedBiome then continue end
            
            local dist = (root.Position - pivot.Position).Magnitude
            if dist < closestDist then
                closestDist = dist
                closestTree = tree
            end
        end
    end
    return closestTree
end

task.spawn(function()
    while task.wait(0.1) do
        if UIParams.farmEnabled then
            if not EquipAxe() then
                status.Text = "❌ Axe not found!"
                task.wait(1)
                continue
            end

            local targetTree = GetClosestTree()
            local char = Players.LocalPlayer.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local humanoid = char and char:FindFirstChildOfClass("Humanoid")
            
            currentTargetTree = targetTree 
            
            if targetTree and root then
                status.Text = "🔥 Chopping: " .. (targetTree.Name or "Tree")
                local targetPos = targetTree:GetPivot().Position
                
                if (root.Position - targetPos).Magnitude > 6 then
                    root.Anchored = false 
                    
                    local p1, p2 = root.Position, targetPos
                    local dir = Vector3.new(p1.X - p2.X, 0, p1.Z - p2.Z)
                    if dir.Magnitude < 0.1 then dir = Vector3.new(1, 0, 0) end
                    dir = dir.Unit
                    local standPos = targetPos + (dir * 5)
                    
                    local excludeList = {}
                    if char then table.insert(excludeList, char) end
                    local treesFolder = Workspace:FindFirstChild("Trees")
                    if treesFolder then table.insert(excludeList, treesFolder) end
                    
                    local rayParams = RaycastParams.new()
                    rayParams.FilterDescendantsInstances = excludeList
                    rayParams.FilterType = Enum.RaycastFilterType.Exclude
                    rayParams.RespectCanCollide = true 
                    
                    local rayOrigin = Vector3.new(standPos.X, targetPos.Y + 30, standPos.Z)
                    local rayResult = Workspace:Raycast(rayOrigin, Vector3.new(0, -100, 0), rayParams)
                    local groundY = targetPos.Y + 3
                    if rayResult then groundY = rayResult.Position.Y + 3.2 end
                    
                    root.Velocity, root.RotVelocity = Vector3.zero, Vector3.zero
                    root.CFrame = CFrame.lookAt(
                        Vector3.new(standPos.X, groundY, standPos.Z), 
                        Vector3.new(targetPos.X, groundY, targetPos.Z)
                    )
                    
                    if humanoid then
                        humanoid.Sit = false
                        if humanoid:GetState() == Enum.HumanoidStateType.Ragdoll or humanoid:GetState() == Enum.HumanoidStateType.FallingDown then
                            humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
                        end
                    end
                    
                    task.wait(0.2)
                    root.Anchored = true 
                    
                else
                    root.CFrame = CFrame.lookAt(root.Position, Vector3.new(targetPos.X, root.Position.Y, targetPos.Z))
                    root.Anchored = true
                end
                
                local safeX, safeY = 20, 60 
                VirtualInputManager:SendMouseButtonEvent(safeX, safeY, 0, true, game, 1)
                wait(0.315)
                VirtualInputManager:SendMouseButtonEvent(safeX, safeY, 0, false, game, 1)
                task.wait(0.5) 
            else
                if UIParams.selectedBiome ~= "Nearest" and root then
                    local center = biomeCenters[UIParams.selectedBiome]
                    local radius = biomeRadiuses[UIParams.selectedBiome]
                    
                    if center and radius then
                        local dist = math.sqrt((root.Position.X - center.X)^2 + (root.Position.Z - center.Z)^2)
                        
                        if dist > radius * 0.9 then
                            status.Text = "✈️ Teleporting to biome: " .. (customBiomeNames[UIParams.selectedBiome] or UIParams.selectedBiome)
                            local props = biomeProps[UIParams.selectedBiome]
                            if props and #props > 0 then
                                local tPos = props[math.random(#props)]
                                
                                local dropRay = RaycastParams.new()
                                if char then dropRay.FilterDescendantsInstances = {char} end
                                dropRay.FilterType = Enum.RaycastFilterType.Exclude
                                dropRay.RespectCanCollide = true
                                local groundHit = Workspace:Raycast(tPos + Vector3.new(0, 100, 0), Vector3.new(0, -200, 0), dropRay)
                                local safeY = tPos.Y + 5
                                if groundHit then safeY = groundHit.Position.Y + 3 end
                                
                                root.Anchored = false
                                root.CFrame = CFrame.new(Vector3.new(tPos.X, safeY, tPos.Z))
                                task.wait(0.5)
                            end
                            continue
                        else
                            status.Text = "⏳ Waiting for trees in " .. (customBiomeNames[UIParams.selectedBiome] or UIParams.selectedBiome)
                        end
                    end
                else
                    status.Text = "🤷‍♂️ No wild trees..."
                end
            end
        end
    end
end)
