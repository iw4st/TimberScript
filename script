local function EvaluateTreeAfterStrike(tree)
    local tMaxHp = nil
    local tNameMatch = false

    local isAnySelected = false
    for _, isSel in pairs(UIParams.selectedTrees) do
        if isSel then isAnySelected = true; break end
    end

    local treeName = string.lower(tree.Name)

    local function checkStringForName(txt)
        if not txt or not isAnySelected then return end
        txt = string.lower(txt)
        for selName, isSel in pairs(UIParams.selectedTrees) do
            if isSel and string.find(txt, string.lower(selName)) then
                tNameMatch = true
            end
        end
    end

    checkStringForName(treeName)
    for attr, val in pairs(tree:GetAttributes()) do
        if type(val) == "string" then checkStringForName(val)
        elseif type(val) == "number" then
            local aName = string.lower(attr)
            if string.find(aName, "health") or string.find(aName, "hp") or string.find(aName, "max") then
                if (not tMaxHp or val > tMaxHp) and val > 10 then tMaxHp = val end
            end
        end
    end

    if tree:FindFirstChild("Origin") then
        for attr, val in pairs(tree.Origin:GetAttributes()) do
            if type(val) == "string" then checkStringForName(val)
            elseif type(val) == "number" then
                local aName = string.lower(attr)
                if string.find(aName, "health") or string.find(aName, "hp") or string.find(aName, "max") then
                    if (not tMaxHp or val > tMaxHp) and val > 10 then tMaxHp = val end
                end
            end
        end
    end

    local hasUI = false
    for _, desc in ipairs(tree:GetDescendants()) do
        if desc:IsA("StringValue") then
            checkStringForName(desc.Value)
        elseif desc:IsA("TextLabel") or desc:IsA("TextBox") or desc:IsA("TextButton") then
            hasUI = true
            local txt = string.lower(desc.Text or "")
            txt = string.gsub(txt, "<.->", "")
            checkStringForName(txt)
            
            if not tMaxHp and string.find(txt, "/") then
                local c, m = string.match(txt, "(%d+[,%d]*)%s*/%s*(%d+[,%d]*)")
                if m then tMaxHp = tonumber((string.gsub(m, ",", ""))) end
            end
        elseif desc:IsA("NumberValue") or desc:IsA("IntValue") then
            local n = string.lower(desc.Name)
            if string.find(n, "max") or string.find(n, "health") or string.find(n, "hp") then
                if (not tMaxHp or desc.Value > tMaxHp) and desc.Value > 10 then 
                    tMaxHp = desc.Value 
                end
            end
        end
    end

    return hasUI, tNameMatch, tMaxHp, isAnySelected
end

local function GetClosestTree()
    local char = Players.LocalPlayer.Character
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end

    local closestDist = math.huge
    local closestTree = nil
    
    local treesFolder = workspace:FindFirstChild("Trees")
    if not treesFolder then return nil end
    
    local selectedBiomeCenter = nil
    if UIParams.selectedBiome ~= "Nearest" then
        selectedBiomeCenter = GetZonePosition(UIParams.selectedBiome)
    end
    
    for _, tree in ipairs(treesFolder:GetChildren()) do
        local treeName = string.lower(tree.Name)
        if string.find(treeName, "debris") then continue end
        
        if blacklistedTrees[tree] and os.clock() < blacklistedTrees[tree] then continue end
        
        if tree:FindFirstChild("Origin") and tree.Origin:FindFirstChild("TreeGrowInfo") and tree.Origin.TreeGrowInfo:FindFirstChild("Container") and tree.Origin.TreeGrowInfo.Container:FindFirstChild("TimeLeft") then
            continue
        end
        
        local hasUI, tNameMatch, tMaxHp, isAnySelected = EvaluateTreeAfterStrike(tree)
        
        if hasUI then
            if isAnySelected and not tNameMatch then continue end
            if UIParams.maxHP and UIParams.maxHP > 0 and UIParams.maxHP < 9999990 then
                if tMaxHp and tMaxHp > UIParams.maxHP then
                    continue
                end
            end
        end
        
        local pivot = tree:GetPivot()
        
        if selectedBiomeCenter then
            local distToCenter = math.sqrt((pivot.Position.X - selectedBiomeCenter.X)^2 + (pivot.Position.Z - selectedBiomeCenter.Z)^2)
            if distToCenter > 600 then continue end
        end
        
        local inBlacklistedBiome = false
        local blacklisted = {"Palv Cove", "Palm Cove"}
        for _, bName in ipairs(blacklisted) do
            local bZone = GetZonePosition(bName)
            if bZone then
                local distToCenter = math.sqrt((pivot.Position.X - bZone.X)^2 + (pivot.Position.Z - bZone.Z)^2)
                if distToCenter <= 400 then
                    inBlacklistedBiome = true
                    break
                end
            end
        end
        if inBlacklistedBiome then continue end
        
        local dist = (root.Position - pivot.Position).Magnitude
        if dist < closestDist then
            closestDist = dist
            closestTree = tree
        end
    end
    return closestTree
end

