local function EquipAxe()
    local char = Players.LocalPlayer.Character
    local backpack = Players.LocalPlayer:FindFirstChild("Backpack")
    if not char or not backpack then return false end

    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return false end

    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") and string.find(string.lower(tool.Name), "axe") then
            return true
        end
    end

    for _, tool in ipairs(backpack:GetChildren()) do
        if tool:IsA("Tool") and string.find(string.lower(tool.Name), "axe") then
            humanoid:EquipTool(tool)
            task.wait(0.2)
            return true
        end
    end
    
    return false
end

local function GetClosestTree()
    local root = Players.LocalPlayer.Character and Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    
    local closestDist = math.huge
    local closestTree = nil
    
    local treesFolder = Workspace:FindFirstChild("Trees")
    if not treesFolder then return nil end
    
    for _, tree in pairs(treesFolder:GetChildren()) do
        if string.find(string.lower(tree.Name), "debris") then continue end
        
        local origin = tree:FindFirstChild("Origin")
        if not origin then continue end 
        
        if not origin:FindFirstChild("TreeHealth") then continue end
        if origin:FindFirstChild("TreeGrowInfo") then continue end
        
        local seed = tree:GetAttribute("Seed")
        local culled = tree:GetAttribute("TreeCulled")
        if seed and culled == false then
            local pivot = tree:GetPivot()
            local dist = (root.Position - pivot.Position).Magnitude
            if dist < closestDist then
                closestDist = dist
                closestTree = tree
            end
        end
    end
    
    return closestTree
end

task.spawn(function()
    while task.wait(0.1) do
        if UIParams.enabled then
            if not EquipAxe() then
                status.Text = "❌ Axe not found!"
                task.wait(1)
                continue
            end

            local targetTree = GetClosestTree()
            local char = Players.LocalPlayer.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local humanoid = char and char:FindFirstChildOfClass("Humanoid")
            
            if targetTree and root then
                status.Text = "🔥 Chopping: " .. (targetTree.Name or "Tree")
                
                local targetPos = targetTree:GetPivot().Position
                
                if (root.Position - targetPos).Magnitude > 6 then
                    
                    local p1 = root.Position
                    local p2 = targetPos
                    local dir = Vector3.new(p1.X - p2.X, 0, p1.Z - p2.Z)
                    if dir.Magnitude < 0.1 then dir = Vector3.new(1, 0, 0) end
                    dir = dir.Unit
                    
                    local standPos = targetPos + (dir * 5)
                    
                    local excludeList = {char}
                    local treesFolder = Workspace:FindFirstChild("Trees")
                    if treesFolder then table.insert(excludeList, treesFolder) end
                    
                    local rayParams = RaycastParams.new()
                    rayParams.FilterDescendantsInstances = excludeList
                    rayParams.FilterType = Enum.RaycastFilterType.Exclude
                    -- 🔥 IGNORING INVISIBLE BLOCKS AND TRIGGERS:
                    rayParams.RespectCanCollide = true 
                    
                    local rayOrigin = Vector3.new(standPos.X, targetPos.Y + 30, standPos.Z)
                    local rayResult = Workspace:Raycast(rayOrigin, Vector3.new(0, -100, 0), rayParams)
                    
                    local groundY = targetPos.Y + 3
                    if rayResult then
                        groundY = rayResult.Position.Y + 3.2 
                    end
                    
                    root.Velocity = Vector3.zero
                    root.RotVelocity = Vector3.zero
                    root.CFrame = CFrame.lookAt(
                        Vector3.new(standPos.X, groundY, standPos.Z), 
                        Vector3.new(targetPos.X, groundY, targetPos.Z)
                    )
                    root.Anchored = true 
                    
                    if humanoid then
                        humanoid.Sit = false
                        if humanoid:GetState() == Enum.HumanoidStateType.Ragdoll or humanoid:GetState() == Enum.HumanoidStateType.FallingDown then
                            humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
                        end
                    end
                    task.wait(0.15) 
                else
                    root.Anchored = true
                    root.CFrame = CFrame.lookAt(root.Position, Vector3.new(targetPos.X, root.Position.Y, targetPos.Z))
                end
                
                local safeX, safeY = 20, 60 
                
                VirtualInputManager:SendMouseButtonEvent(safeX, safeY, 0, true, game, 1)
                wait(0.315)
                VirtualInputManager:SendMouseButtonEvent(safeX, safeY, 0, false, game, 1)
                
                task.wait(0.5) 
            else
                status.Text = "🤷♂️ No trees nearby..."
            end
        end
    end
end)
